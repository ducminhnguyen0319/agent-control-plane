  ensure_ordered_ready_issue_ids_cache
  printf '%s\n' "$ordered_ready_issue_ids_cache"
}

due_scheduled_issue_ids() {
  ensure_due_scheduled_issue_ids_cache
  printf '%s\n' "$due_scheduled_issue_ids_cache"
